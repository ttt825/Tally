<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tab背景设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="模糊程度"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tv_blur_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_blur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="9"
            android:progress="4"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="圆角程度"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tv_corner_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50dp"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_corner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="99"
            android:progress="49"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="透明度"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tv_opacity_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="80%"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_opacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="80"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="阴影大小"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tv_shadow_size_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.5dp"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_shadow_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="1"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="阴影透明度"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tv_shadow_opacity_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25%"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"/>
        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_shadow_opacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="50"
            android:progress="25"
            android:layout_marginBottom="28dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/input_bg"
                android:text="取 消"
                android:textColor="@color/text_primary"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:backgroundTint="?attr/colorPrimary"
                android:text="确 定"
                android:textColor="@color/text_white"
                app:cornerRadius="16dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>