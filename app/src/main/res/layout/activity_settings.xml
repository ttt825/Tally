<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:importantForAccessibility="noHideDescendants"
    android:orientation="vertical"
    android:background="@color/bar_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingBottom="16dp"
        android:paddingTop="8dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="always">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/btn_category_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="分类预设设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                <TextView
                    android:id="@+id/btn_backup_restore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="数据备份与恢复"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                

                <TextView
                    android:id="@+id/btn_toggle_night_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="主题样式设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                

                <TextView
                    android:id="@+id/btn_currency_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="货币单位设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                <TextView
                    android:id="@+id/btn_amount_display_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="金额显示设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:id="@+id/divider_donate"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                <TextView
                    android:id="@+id/btn_photo_backup_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="照片备份设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                <TextView
                    android:id="@+id/btn_auto_backup_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="自动备份设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                <TextView
                    android:id="@+id/btn_security_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="安全密码设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>

                <TextView
                    android:id="@+id/btn_tab_background_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="Tab背景设置"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginHorizontal="20dp"/>


                <TextView
                    android:id="@+id/btn_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="关于"
                    android:textSize="16sp"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="?android:attr/textColorPrimary"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.cardview.widget.CardView>

</LinearLayout>