<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialog_advanced_filter"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_transaction_type"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/sp_filter_type"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_field"
            android:popupBackground="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:spinnerMode="dropdown"
            android:dropDownVerticalOffset="52dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_amount_range"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_min_amount"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:hint="最小"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"/>

            <View android:layout_width="12dp" android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_gravity="center"
                android:layout_marginHorizontal="8dp"/>

            <EditText
                android:id="@+id/et_max_amount"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:hint="最大"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_category_keyword"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_category"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="输入分类名称"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_remark_contains"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_asset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="输入备注关键字"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/btn_reset"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/input_bg"
                app:cornerRadius="16dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_apply"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/btn_confirm"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/app_accent"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>