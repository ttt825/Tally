# Android 签名密钥配置文件
# 
# 使用说明：
# 1. 复制此文件并重命名为 keystore.properties
# 2. 填写实际的密钥信息
# 3. 不要将 keystore.properties 提交到 Git（已在 .gitignore 中）

# 密钥库文件路径（相对于项目根目录）
storeFile=budgetapp-release.keystore

# 密钥库密码
storePassword=YOUR_KEYSTORE_PASSWORD

# 密钥别名
keyAlias=budgetapp

# 密钥密码
keyPassword=YOUR_KEY_PASSWORD
