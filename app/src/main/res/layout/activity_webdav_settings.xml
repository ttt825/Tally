<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bar_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WebDAV 备份设置"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="24dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- 自动同步开关 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="自动同步"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="数据变动时自动上传到WebDAV"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_auto_sync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumb="@drawable/switch_thumb_custom"
                        app:track="@drawable/switch_track_custom"
                        app:showText="false"
                        app:thumbTint="@null"
                        app:trackTint="@null"
                        android:background="@null" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WebDAV配置表单 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="服务器地址"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_webdav_url"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="例如: https://dav.jianguoyun.com/dav/"
                        android:inputType="textUri"
                        android:paddingHorizontal="18dp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textColorHint="?android:attr/textColorHint"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="用户名/账号"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_webdav_username"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="输入用户名"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="18dp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textColorHint="?android:attr/textColorHint"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="密码/应用授权码"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_webdav_password"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="输入密码或授权码"
                        android:inputType="textPassword"
                        android:paddingHorizontal="18dp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textColorHint="?android:attr/textColorHint"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_webdav"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="保存配置"
                        android:textColor="@color/real_white"
                        android:textStyle="bold"
                        android:backgroundTint="@color/app_blue"
                        app:cornerRadius="16dp"
                        app:elevation="0dp"
                        app:pressedTranslationZ="0dp"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_upload_data"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="上传数据"
                            android:textColor="@color/text_primary"
                            android:backgroundTint="@color/input_bg"
                            app:cornerRadius="16dp"
                            app:elevation="0dp"
                            app:pressedTranslationZ="0dp"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_sync_data"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="同步数据"
                            android:textColor="@color/text_primary"
                            android:backgroundTint="@color/input_bg"
                            app:cornerRadius="16dp"
                            app:elevation="0dp"
                            app:pressedTranslationZ="0dp"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- 上次备份时间提示 -->
    <TextView
        android:id="@+id/tv_last_backup_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="暂无备份记录"
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:background="@color/bar_background" />
</LinearLayout>