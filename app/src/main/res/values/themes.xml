<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.BudgetApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/app_accent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/white</item>

        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="TransparentIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>

    <style name="RoundedBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@android:color/transparent</item>
        <item name="itemIconTint">@color/selector_bottom_nav</item>
        <item name="itemTextColor">@color/selector_bottom_nav</item>
        <item name="itemActiveIndicatorStyle">@style/RoundedActiveIndicator</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="RoundedActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
        <item name="marginHorizontal">0dp</item>
        <item name="android:color">@android:color/transparent</item>
    </style>

    <style name="Theme.BudgetApp" parent="Base.Theme.BudgetApp" />

    <style name="ThemeOverlay.App.DatePicker" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/app_accent</item>
        <item name="colorOnPrimary">#000000</item>

        <item name="android:elevation">0dp</item>
        <item name="elevation">0dp</item>

        <item name="buttonBarPositiveButtonStyle">@style/Widget.App.DatePicker.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.App.DatePicker.Button</item>
    </style>

    <style name="Widget.App.DatePicker.Button" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/app_accent</item>
    </style>

    <style name="ThemeOverlay.App.NumberPicker" parent="ThemeOverlay.Material3.DynamicColors.DayNight">
        <item name="android:selectionDividerHeight">0dp</item>
        <item name="android:colorControlNormal">@android:color/transparent</item>
    </style>

    <style name="CircularFabShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.BudgetApp.Transparent" parent="Theme.BudgetApp">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="Animation.Dialog" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

</resources>