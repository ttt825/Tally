<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notice_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bar_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tv_notice_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="用户须知"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="项目简介"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tally 是一个功能强大的记账应用，拥有自动记账、AI 智能记账、照片备份、WebDAV 云备份、自动续费提醒、多币种、关联资产等核心功能。所有数据存储在本地，可完全离线使用。WebDAV 云备份和 AI 记账功能需要联网，但完全由用户控制。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="功能默认情况"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 记账助手设置：“开启屏幕自动记账”关闭，“开启资产功能”开启\n• 自动资产设置：“开启自动资产”关闭\n• 分类预设管理：“开启二级分类”关闭\n• 记账界面默认显示：“结余”\n• 货币单位设置：“开启货币单位”关闭，默认“￥”\n• 照片备注设置：“开启照片备份”关闭。备份为纯本地存储（原理是复制一份至指定路径），推荐新建以“.”开头（如 .Tally）的空白文件夹作为存储路径\n• 主题设置：“跟随系统”\n• 极简模式：关闭\n\n💡 隐藏彩蛋：长按当前界面左上角的“用户须知”标题，可以取消激活高级设置。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="项目权限清单"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 自启动：用于自动记账进程的后台保活。\n• 无障碍：实现屏幕读取与自动记账的核心权限。\n• 悬浮窗：用于 1 像素保活机制及记账时的即时弹窗交互。\n• 通知：提供实时状态反馈，自动记账功能稳定后可手动关闭。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="10dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动记账配置"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="使用“无障碍管理器”锁死 Tally 的无障碍权限。\n“无障碍管理器”和“shizuku”在123链接里面的“辅助软件”，具体使用方法看B站视频。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="无障碍原理"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tally的自动记账功能依赖于无障碍权限，下面的原理适用于“记账助手设置”、“自动记账设置”：\n\n• 触发机制：只要在指定的应用内的屏幕出现了设定的关键字，就会触发自动记账（弹出悬浮窗、自动输入对应的金额）。例如，在“微信”这个应用设定关键字“微信”，那么每次打开“微信”都会触发自动记账。\n• 注意事项：无障碍不识别图片。\n• 资产关联：“自动资产设置”是对自动记账功能的补充，如果没有设定相关的自动资产，那么记账会关联默认资产（长按资产设置默认资产）。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="隐私安全承诺"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="由于使用到的权限较为敏感，Tally 承诺完全不具备联网功能，未来也不会添加。如有云同步等需求，建议参考开源代码自行扩展。关注酷安 “Tally” 项目，不定时发布版本更新。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="联系我"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="如果有bug反馈或者有新的想法，可以在评论区里发表想法。也可以私信我，酷安“柏芸”、B站“路过的柏芸”。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <Button
                    android:id="@+id/btn_copy_github"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="https://github.com/cypressincloud/Tally"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="#888888"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    app:rippleColor="@android:color/transparent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击后复制到剪切板"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"/>

                <Button
                    android:id="@+id/btn_copy_123pan"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="https://www.123pan.com/s/Ih5uVv-nYapd.html"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="#888888"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    app:rippleColor="@android:color/transparent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击后复制到剪切板"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>