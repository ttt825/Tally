<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notice_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:importantForAccessibility="noHideDescendants"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bar_background">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tv_notice_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="用户须知"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="项目简介"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tally 是一个功能强大的记账应用，拥有自动记账、AI 智能记账、照片备份、WebDAV 云备份、自动续费提醒、多币种、关联资产等核心功能。所有数据存储在本地，可完全离线使用。WebDAV 云备份和 AI 记账功能需要联网，但完全由用户控制。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="功能默认情况"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 记账助手设置：&quot;开启屏幕自动记账&quot;关闭，&quot;开启资产功能&quot;开启\n• 资产设置：&quot;开启自动资产&quot;关闭\n• 分类预设管理：&quot;开启二级分类&quot;关闭\n• 记账界面默认显示：&quot;结余&quot;\n• 货币单位设置：&quot;开启货币单位&quot;关闭，默认&quot;￥&quot;\n• 照片备注设置：&quot;开启照片备份&quot;关闭。备份为纯本地存储（原理是复制一份至指定路径），推荐新建以&quot;.&quot;开头（如 .Tally）的空白文件夹作为存储路径\n• WebDAV 云备份：&quot;自动同步&quot;关闭。需配置 WebDAV 服务器地址、用户名和密码，支持坚果云等网盘服务。开启自动同步后，每次记账、修改资产、修改分类等操作都会自动备份到云端\n• AI 记账配置：&quot;启用 AI 记账&quot;关闭。需配置兼容 OpenAI 的 API 服务（如 DeepSeek、通义千问等），支持文本、图片、语音识别。可设置 AI 分类关键字规则，自动应用分类\n• 主题设置：&quot;跟随系统&quot;\n• 极简模式：关闭\n\n💡 隐藏彩蛋：长按当前界面左上角的&quot;用户须知&quot;标题，可以取消激活高级设置。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="项目权限清单"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 自启动：用于自动记账进程的后台保活。\n• 无障碍：实现屏幕读取与自动记账的核心权限。\n• 悬浮窗：用于 1 像素保活机制及记账时的即时弹窗交互。\n• 通知：提供实时状态反馈，自动记账功能稳定后可手动关闭。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="10dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动记账配置"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="使用&quot;无障碍管理器&quot;锁死 Tally 的无障碍权限。\n&quot;无障碍管理器&quot;和&quot;shizuku&quot;在123链接里面的&quot;辅助软件&quot;，具体使用方法看B站视频。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="无障碍原理"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tally的自动记账功能依赖于无障碍权限，下面的原理适用于&quot;记账助手设置&quot;、&quot;自动记账设置&quot;：\n\n• 触发机制：只要在指定的应用内的屏幕出现了设定的关键字，就会触发自动记账（弹出悬浮窗、自动输入对应的金额）。例如，在&quot;微信&quot;这个应用设定关键字&quot;微信&quot;，那么每次打开&quot;微信&quot;都会触发自动记账。\n• 注意事项：无障碍不识别图片。\n• 资产关联：&quot;资产设置&quot;是对自动记账功能的补充，如果没有设定相关的自动资产，那么记账会关联默认资产（长按资产设置默认资产）。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WebDAV 云备份使用方法"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WebDAV 是一种网络文件传输协议，可以将数据备份到支持 WebDAV 的网盘服务。\n\n配置步骤：\n1. 进入&quot;设置&quot; → &quot;WebDAV 云备份&quot;\n2. 填写 WebDAV 服务器地址（如坚果云提供的地址）\n3. 填写用户名和密码（坚果云需使用应用密码）\n4. 点击&quot;保存配置&quot;\n5. 点击&quot;测试连接&quot;验证配置是否正确\n6. 开启&quot;自动同步&quot;开关（可选）\n\n使用说明：\n• 手动备份：点击&quot;上传数据&quot;按钮\n• 手动恢复：点击&quot;同步数据&quot;按钮（会覆盖本地数据）\n• 自动备份：开启后，每次记账、修改资产、修改分类等操作都会自动上传\n• 备份内容：包含所有交易记录、资产账户、目标、分类设置等\n\n推荐网盘：\n• 坚果云（国内稳定，免费版每月1GB上传流量）\n• Teracloud（日本服务，免费10GB空间）\n• Box.com（国际服务，免费10GB空间）"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI 记账使用方法"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI 记账功能可以通过文本、图片、语音识别账单信息，自动填写记账表单。\n\n配置步骤：\n1. 进入&quot;设置&quot; → &quot;AI 记账配置&quot;\n2. 填写 API Base URL（如 https://api.deepseek.com）\n3. 填写 API Key（从服务商获取）\n4. 填写模型名称：\n   - 文本模型（必填）：如 deepseek-chat\n   - 视觉模型（可选）：如 deepseek-vision（支持图片识别）\n   - 音频模型（可选）：如 whisper-1（支持语音识别）\n5. 点击&quot;测试连接&quot;验证配置\n6. 点击&quot;保存配置&quot;并开启&quot;启用 AI 记账&quot;\n\n使用说明：\n• 文本识别：在记账页面输入账单描述，AI 自动识别金额、分类等\n• 图片识别：拍摄或选择账单照片，AI 自动提取信息\n• 语音识别：语音输入账单信息，AI 转换为文字并识别\n• 分类规则：在&quot;AI 分类关键字规则&quot;中设置关键字映射，提高分类准确性\n\n推荐服务商：\n• Longcat（国内，每天有免费额度，适合轻度使用）\n• DeepSeek（国内，性价比高，1元/百万tokens）\n• 通义千问（阿里云，免费额度较多）\n• OpenAI（国际标准，需科学上网）\n\n注意事项：\n• API 调用需要消耗服务商的额度或费用\n• 建议使用国内服务商，速度更快\n• 首次使用建议先测试连接，确保配置正确"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="资产图标设置"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="为资产账户设置个性化的 SVG 图标，让资产列表更加直观美观。\n\n使用方法：\n1. 进入&quot;资产&quot;页面，点击任意资产进入编辑\n2. 在编辑界面找到&quot;设置图标&quot;按钮\n3. 点击&quot;获取图标&quot;按钮，跳转到 iconfont 图标库\n4. 在 iconfont 网站搜索并选择喜欢的图标\n5. 点击图标下方的&quot;复制 SVG 代码&quot;按钮\n6. 返回应用，将 SVG 代码粘贴到输入框\n7. 点击&quot;生成预览&quot;查看效果\n8. 确认无误后点击&quot;保存&quot;\n\niconfont 使用技巧：\n• 搜索关键词：如&quot;银行&quot;、&quot;钱包&quot;、&quot;信用卡&quot;等\n• 选择单色图标：效果更好，与应用风格统一\n• 复制完整代码：确保包含 &lt;svg&gt; 开始和 &lt;/svg&gt; 结束标签\n• 图标尺寸：应用会自动调整为 24dp，无需手动修改\n\n注意事项：\n• 图标会在资产列表中显示，帮助快速识别不同账户\n• 支持所有资产类型：资产、负债、借出、理财、分期\n• 图标数据会随备份一起保存和恢复\n• 如果 SVG 代码无法解析，请检查代码完整性"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="隐私安全承诺"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="由于使用到的权限较为敏感，Tally 承诺：\n\n• 应用可完全离线使用，所有核心功能不依赖网络\n• 联网功能仅用于 WebDAV 云备份和 AI 记账，需用户主动配置和启用\n• 所有数据存储在本地，用户拥有完全控制权\n• 不收集、不上传任何个人隐私数据\n• 开源代码可供审查，确保透明可信\n\n关注酷安 &quot;Tally&quot; 项目，不定时发布版本更新。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="联系我"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="如果有bug反馈或者有新的想法，可以在评论区里发表想法。也可以私信我，酷安&quot;柏芸&quot;、B站&quot;路过的柏芸&quot;。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <Button
                    android:id="@+id/btn_copy_github"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="https://github.com/cypressincloud/Tally"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="#888888"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    app:rippleColor="@android:color/transparent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击后复制到剪切板"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"/>

                <Button
                    android:id="@+id/btn_copy_123pan"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="https://www.123pan.com/s/Ih5uVv-nYapd.html"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="#888888"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    app:rippleColor="@android:color/transparent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击后复制到剪切板"
                    android:textSize="11sp"
                    android:textColor="#999999"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>
