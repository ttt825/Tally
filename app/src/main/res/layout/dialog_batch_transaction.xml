<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/app_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scrollbars="none"
            android:fadeScrollbars="false"
            app:layout_constraintHeight_default="wrap"
            app:layout_constraintHeight_max="680dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_batch_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="记多笔"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_gravity="center_horizontal"/>

                <TextView
                    android:id="@+id/tv_batch_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_gravity="start"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp"
                    android:background="?android:attr/selectableItemBackground"/>

                <RadioGroup
                    android:id="@+id/rg_batch_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/rb_batch_expense"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="支出"
                        android:gravity="center"
                        android:button="@null"
                        android:background="@drawable/bg_type_selector"
                        android:textColor="@color/text_type_selector"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:checked="true"
                        android:layout_marginEnd="4dp"/>

                    <RadioButton
                        android:id="@+id/rb_batch_income"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="收入"
                        android:gravity="center"
                        android:button="@null"
                        android:background="@drawable/bg_type_selector"
                        android:textColor="@color/text_type_selector"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="4dp"/>

                    <RadioButton
                        android:id="@+id/rb_batch_lend"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="借出"
                        android:gravity="center"
                        android:button="@null"
                        android:background="@drawable/bg_type_selector"
                        android:textColor="@color/text_type_selector"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="4dp"/>

                    <RadioButton
                        android:id="@+id/rb_batch_liability"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="借入"
                        android:gravity="center"
                        android:button="@null"
                        android:background="@drawable/bg_type_selector"
                        android:textColor="@color/text_type_selector"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="金额"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/tv_batch_col2_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="类型"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="备注"
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_batch_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <ImageButton
                    android:id="@+id/btn_add_row"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:src="@drawable/ic_add"
                    android:background="@drawable/bg_input_field"
                    android:contentDescription="新增一行"
                    app:tint="@color/app_accent"
                    android:scaleType="center"/>

                <EditText
                    android:id="@+id/et_batch_record_id"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="记录标识"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textColorHint="?android:attr/textColorHint"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="10dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btn_batch_save"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:text="保 存"
                    android:textColor="@color/text_white"
                    app:cornerRadius="16dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
