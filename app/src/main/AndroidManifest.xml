<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:name=".MyApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.BudgetApp">

        <activity
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustPan"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.budgetapp.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity android:name=".ui.PhotoBackupSettingsActivity"
            android:label="照片备份设置"
            android:theme="@style/Theme.BudgetApp"/>

        <activity android:name=".ui.AutoBackupSettingsActivity"
            android:label="自动备份设置"
            android:theme="@style/Theme.BudgetApp"/>

        <activity android:name=".ui.ThemeSettingsActivity" />
        <activity android:name=".ui.CropActivity" android:theme="@style/Theme.BudgetApp" />

        <activity android:name=".ui.PhotoActionActivity"
            android:theme="@style/Theme.BudgetApp.Transparent"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"/>

        <activity
            android:name=".ui.AboutActivity"
            android:label="关于"
            android:theme="@style/Theme.BudgetApp"
            android:exported="false"/>

        <activity
            android:name=".ui.SettingsActivity"
            android:label="设置"
            android:theme="@style/Theme.BudgetApp"
            android:exported="false"/>

        <activity
            android:name=".ui.DonateActivity"
            android:label="捐赠支持"
            android:theme="@style/Theme.BudgetApp"
            android:exported="false"/>

        <activity
            android:name=".ui.SecuritySettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".ui.AuthActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <activity
            android:name=".ui.CategorySettingsActivity"
            android:label="分类预设管理"
            android:theme="@style/Theme.BudgetApp"
            android:exported="false"/>

        

        <activity
            android:name=".ui.YearCalendarActivity"
            android:label="年度账单"
            android:theme="@style/Theme.BudgetApp"
            android:exported="false"/>

        <activity android:name=".ui.UserNoticeActivity" />

        <activity
            android:name=".ui.CurrencySettingsActivity"
            android:exported="false" />

        <service
            android:name=".service.QuickAddTileService"
            android:icon="@drawable/ic_qs_record"
            android:label="记一笔"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        

        <receiver
            android:name=".widget.TodaySummaryWidget"
            android:exported="true"
            android:label="@string/widget_name_today"> <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
        </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_summary_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.MonthSummaryWidget"
            android:exported="true"
            android:label="@string/widget_name_month"> <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
        </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/month_summary_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.CombinedSummaryWidget"
            android:exported="true"
            android:label="@string/widget_name_combined"> <intent-filter>
            <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
        </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/combined_summary_widget_info" />
        </receiver>

        </application>

</manifest>