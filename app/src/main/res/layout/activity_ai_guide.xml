<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_guide_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bar_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 记账配置指南"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 使用提醒 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/ai_guide_hint_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 使用提醒"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/ai_guide_hint_title"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• 点击链接可直接跳转到对应网站\n• 长按示例框可快速复制内容"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/ai_guide_hint_text"/>
                </LinearLayout>

                <!-- 功能简介 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="功能简介"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI 记账功能支持通过文本、截图、语音三种方式智能识别账单信息，自动填写记账表单。配置完成后，您可以：\n\n• 文本记账：输入账单描述，AI 自动识别金额、分类\n• 截图记账：拍摄或选择账单照片，AI 提取关键信息\n• 语音记账：语音输入账单，AI 转换并识别内容"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <!-- 配置步骤 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="配置步骤"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="以美团 LongCat 大模型为例，演示如何获取配置参数："
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <!-- 步骤 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="步骤 1：获取接口地址"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="?android:attr/colorPrimary"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. 访问 LongCat 平台：https://longcat.chat/platform/usage\n2. 点击左侧菜单「接口文档」\n3. 找到「接口端点」部分\n4. 复制 OpenAI 格式的接入端点"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp"
                        android:layout_marginTop="8dp"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_step1_url"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="访问：https://longcat.chat/platform/usage"
                            android:textSize="13sp"
                            android:padding="8dp"
                            android:background="@color/ai_guide_example_bg"
                            android:textColor="@color/ai_guide_link"
                            android:fontFamily="monospace"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击跳转"
                            android:textSize="11sp"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_step1_example"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="示例：https://api.longcat.chat/openai"
                            android:textSize="13sp"
                            android:padding="8dp"
                            android:background="@color/ai_guide_example_bg"
                            android:textColor="@color/ai_guide_link"
                            android:fontFamily="monospace"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="长按复制"
                            android:textSize="11sp"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 这就是应用内「接口地址」字段的值"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/income_red"/>
                </LinearLayout>

                <!-- 步骤 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="步骤 2：创建 API Key"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="?android:attr/colorPrimary"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. 再次点击左侧菜单，选择「API Keys」\n2. 或直接访问：https://longcat.chat/platform/api_keys\n3. 点击「创建API Key」按钮\n4. 输入密钥名称（任意命名，如：Tally记账）\n5. 点击创建，复制生成的 Key"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp"
                        android:layout_marginTop="8dp"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_step2_url"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="访问：https://longcat.chat/platform/api_keys"
                            android:textSize="13sp"
                            android:padding="8dp"
                            android:background="@color/ai_guide_example_bg"
                            android:textColor="@color/ai_guide_link"
                            android:fontFamily="monospace"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击跳转"
                            android:textSize="11sp"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_step2_example"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="示例：ak-xxxxxxxxxxxxxxxxxxxxxxxx"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:padding="8dp"
                        android:background="@color/ai_guide_example_bg"
                        android:textColor="@color/ai_guide_link"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 这就是应用内「API Key」字段的值\n⚠️ 密钥仅显示一次，请妥善保存"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/income_red"/>
                </LinearLayout>

                <!-- 步骤 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="步骤 3：选择模型"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="?android:attr/colorPrimary"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. 返回「接口文档」页面\n2. 查看「支持的模型」部分\n3. 根据需求选择合适的模型：\n   • 文本模型（必填）：用于文本记账\n   • 视觉模型（可选）：用于截图记账\n   • 音频模型（可选）：用于语音记账"
                        android:textSize="14sp"
                        android:lineSpacingExtra="6dp"
                        android:layout_marginTop="8dp"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="LongCat 推荐配置："
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:textColor="?android:attr/textColorPrimary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_step3_model"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="• 文本模型：LongCat-Flash-Chat-2602-Exps\n• 视觉模型：LongCat-Flash-Chat-2602-Exps"
                            android:textSize="13sp"
                            android:padding="8dp"
                            android:background="@color/ai_guide_example_bg"
                            android:textColor="@color/ai_guide_link"
                            android:fontFamily="monospace"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="长按复制"
                            android:textSize="11sp"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 该模型同时支持文本和视觉输入，可用于文本记账和截图记账"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/income_red"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <!-- 应用内配置 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="应用内配置"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="获取到上述参数后，在应用内进行配置："
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. 打开应用，进入「设置」→「AI 记账配置」\n2. 填写「接口地址」：https://api.longcat.chat/openai\n3. 填写「API Key」：您创建的密钥\n4. 填写「文本模型」：LongCat-Flash-Chat-2602-Exps\n5. 填写「视觉模型」：LongCat-Flash-Chat-2602-Exps（可选）\n6. 点击「测试连接」验证配置\n7. 测试成功后，点击「保存配置」\n8. 开启「启用 AI 记账」开关"
                    android:textSize="14sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorSecondary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <!-- 其他平台配置 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="其他平台配置"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="除了 LongCat，您还可以使用其他兼容 OpenAI 格式的 AI 服务平台（如 DeepSeek、通义千问、Kimi、豆包等）。\n\n配置方法与上述步骤相同：\n1. 访问对应平台的控制台\n2. 找到接口文档，获取接口地址\n3. 创建 API Key\n4. 查看支持的模型列表\n5. 在应用内填写配置信息\n\n💡 提示：大部分平台都提供免费额度或试用，建议优先选择国内服务商以获得更快的响应速度。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="10dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <!-- 注意事项 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="注意事项"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 模型能力：部分平台的模型列表会标注支持的输入类型（文本/视觉/音频），如未标注需自行测试\n• 费用说明：AI 调用会消耗服务商的额度或产生费用，建议选择有免费额度的平台\n• 网络要求：建议使用国内服务商，响应速度更快\n• 隐私安全：您的账单数据仅发送至您配置的 AI 服务商，应用本身不会收集或存储\n• 首次使用：建议先使用「测试连接」功能，确保配置正确后再启用"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F888888"
                    android:layout_marginVertical="24dp"/>

                <!-- 常见问题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="常见问题"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="?android:attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Q：测试连接失败怎么办？\nA：请检查接口地址和 API Key 是否正确，确保网络连接正常。\n\nQ：如何知道模型是否支持视觉输入？\nA：查看平台的接口文档，或在应用内测试截图记账功能。\n\nQ：AI 识别不准确怎么办？\nA：可以在「AI 分类关键字规则」中设置关键字映射，提高分类准确性。\n\nQ：可以同时配置多个平台吗？\nA：可以，但需要分别配置。应用支持配置多个 AI 服务，您可以根据需要切换使用不同的平台。"
                    android:textSize="15sp"
                    android:lineSpacingExtra="8dp"
                    android:layout_marginTop="12dp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginBottom="20dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>
