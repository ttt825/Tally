<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notice_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:importantForAccessibility="noHideDescendants"
    android:orientation="vertical"
    android:background="@color/bar_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tv_notice_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="用户须知"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="2290dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="项目简介"
                    android:textColor="?android:attr/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="6dp"
                    android:text="Tally 是一款纯本地记账应用，所有数据仅存储在设备本地。支持支出、收入、借入、借出四种账单类型，提供日历月视图与年视图、明细筛选、统计分析等核心功能。特色功能包括：照片记账与备份、多币种支持、二级分类管理、自动备份（JSON 全量数据）、微信/支付宝账单导入、桌面小组件、加班记录、自定义背景与主题、安全密码与生物识别锁等。"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="#1F888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="功能默认情况"
                    android:textColor="?android:attr/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="8dp"
                    android:text="• 分类预设管理：&quot;开启二级分类&quot;关闭，&quot;开启详细分类&quot;关闭\n• 记账界面默认显示：&quot;结余&quot;\n• 货币单位设置：&quot;开启货币单位&quot;关闭，默认&quot;￥&quot;\n• 照片备份设置：&quot;开启照片备份&quot;关闭。备份为纯本地存储\n• 自动备份设置：&quot;开启自动备份&quot;关闭。开启后可设定备份频次，账单变动达到次数后自动导出 JSON 全量数据到指定路径\n• 主题样式设置：&quot;跟随系统&quot;，可选浅色/深色/自定义背景\n• 安全密码设置：密码锁与生物识别均关闭\n• Tab 背景设置：默认模糊级别 5、圆角 50dp、不透明度 100%。"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="#1F888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="项目权限清单"
                    android:textColor="?android:attr/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="10dp"
                    android:text="• 相机：用于拍照记账，为账单附加凭证照片。\n• 存储/文件：用于数据导出导入（JSON/CSV）、照片备份、自定义背景图片读取。\n• 通知：提供实时状态反馈。\n• 悬浮窗：用于快捷记账弹窗交互。\n• 生物识别：用于应用锁的身份验证。"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="#1F888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据备份说明"
                    android:textColor="?android:attr/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="8dp"
                    android:text="• 导出数据（Json）：导出全部数据，包括账单记录、分类信息、应用偏好设置等，推荐用于完整备份与迁移恢复。\n• 导出账单（CSV）：仅导出交易记录，适合用 Excel 等工具查看分析。\n• 导入数据（Json）：从 Json 备份文件恢复全部数据（合并模式，自动去重并追加新记录）。\n• 导入账单（CSV）：仅导入交易记录。\n• 从微信/支付宝导入：支持导入微信账单（xlsx/csv）和支付宝账单（csv），自动匹配分类。\n• 自动备份：开启后，账单变动达到设定频次即自动导出 Json 全量数据到指定路径，每次备份生成独立文件。"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="#1F888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="隐私安全承诺"
                    android:textColor="?android:attr/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="6dp"
                    android:text="Tally 承诺完全不具备联网功能，未来也不会添加。所有数据仅存储在设备本地，不会上传至任何服务器。如有云同步等需求，建议参考开源代码自行扩展。关注酷安 &quot;Tally&quot; 项目，不定时发布版本更新。"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="24dp"
                    android:background="#1F888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="联系我"
                    android:textColor="?android:attr/colorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="6dp"
                    android:text="如果有bug反馈或者有新的想法，可以在评论区里发表想法。也可以私信我，酷安&quot;柏芸&quot;、B站&quot;路过的柏芸&quot;。"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btn_copy_github"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    android:text="https://github.com/cypressincloud/Tally"
                    android:textAllCaps="false"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    app:rippleColor="@android:color/transparent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="点击后复制到剪切板"
                    android:textColor="#999999"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btn_copy_123pan"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="https://www.123pan.com/s/Ih5uVv-nYapd.html"
                    android:textAllCaps="false"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    app:rippleColor="@android:color/transparent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"
                    android:text="点击后复制到剪切板"
                    android:textColor="#999999"
                    android:textSize="11sp" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>