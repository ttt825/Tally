<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:importantForAccessibility="noHideDescendants"
    android:background="@color/bar_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_top_title"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/bar_background"
            android:gravity="center"
            android:text="预算"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_month_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本月预算累积结余"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tv_total_surplus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_blue"
                    android:layout_marginTop="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layout_monthly_budget"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/ripple_stat_item"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="4dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="月总预算"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:id="@+id/tv_header_monthly_budget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="今日预计可用"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:id="@+id/tv_header_daily_available"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout_budget"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bar_background"
            app:tabIndicatorColor="@color/app_blue"
            app:tabSelectedTextColor="?android:attr/textColorPrimary"
            app:tabTextColor="@color/text_secondary"
            app:tabRippleColor="@android:color/transparent"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_goals_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="存储目标"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_budget"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/fab_container_budget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:gravity="center_horizontal">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_budget_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_history"
            android:contentDescription="历史记录"
            app:backgroundTint="@color/white"
            app:tint="@color/app_blue"
            app:fabSize="mini"
            app:elevation="0dp"
            app:pressedTranslationZ="0dp"
            app:borderWidth="0dp"
            android:stateListAnimator="@null" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_add_goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="添加目标"
            app:tint="@color/text_white"
            app:backgroundTint="@color/app_blue"
            app:elevation="0dp"
            app:pressedTranslationZ="0dp"
            app:borderWidth="0dp"
            android:stateListAnimator="@null" />
    </LinearLayout>
</RelativeLayout>