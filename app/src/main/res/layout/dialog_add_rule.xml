<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="添加规则"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关键字"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <com.example.budgetapp.ui.CustomHighlightEditText
                android:id="@+id/et_keyword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:hint="输入关键字，多个关键字用空格分隔"
                android:paddingHorizontal="20dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorHint"
                android:textSize="16sp"
                android:maxLines="1"
                android:inputType="text"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_example"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="例如：外卖 美团 饿了么"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择类型"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rg_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rb_expense"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="支出"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/bg_type_selector"
                    android:textColor="@color/text_type_selector"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:checked="true"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/rb_income"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="收入"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/bg_type_selector"
                    android:textColor="@color/text_type_selector"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"/>
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择分类"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tv_selected_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已选择：未选择"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="将创建 N 条规则"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="取 消"
                    android:textColor="?android:attr/textColorSecondary"
                    android:backgroundTint="@color/input_bg"
                    app:cornerRadius="16dp"
                    app:elevation="0dp"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_confirm"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="确 定"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:backgroundTint="@color/app_blue"
                    app:cornerRadius="16dp"
                    app:elevation="0dp"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>