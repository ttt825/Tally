<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="设置加班薪资标准"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="每月底薪"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <com.example.budgetapp.ui.CustomHighlightEditText
        android:id="@+id/et_base_salary"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_field"
        android:hint="请输入每月底薪"
        android:inputType="numberDecimal"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorHint"
        android:paddingHorizontal="16dp"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="工作日时薪"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <com.example.budgetapp.ui.CustomHighlightEditText
        android:id="@+id/et_weekday_rate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_field"
        android:hint="请输入工作日时薪"
        android:inputType="numberDecimal"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorHint"
        android:paddingHorizontal="16dp"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="节假日(周末)时薪"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <com.example.budgetapp.ui.CustomHighlightEditText
        android:id="@+id/et_holiday_rate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_field"
        android:hint="请输入节假日时薪"
        android:inputType="numberDecimal"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorHint"
        android:paddingHorizontal="16dp"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/btn_cancel_overtime"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="取 消"
            android:textColor="?android:attr/textColorSecondary"
            android:backgroundTint="@color/input_bg"
            android:layout_marginEnd="8dp"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

        <Button
            android:id="@+id/btn_save_overtime"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="保 存"
            android:textColor="@color/real_white"
            android:backgroundTint="@color/app_blue"
            android:layout_marginStart="8dp"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
    </LinearLayout>

</LinearLayout>