<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:maxHeight="600dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="添加资产"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <RadioGroup
            android:id="@+id/rg_asset_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <RadioButton
                android:id="@+id/rb_asset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="资产"
                android:layout_marginEnd="16dp"/>

            <RadioButton
                android:id="@+id/rb_investment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="理财"/>

            <RadioButton
                android:id="@+id/rb_liability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="负债"
                android:layout_marginEnd="16dp"/>

            <RadioButton
                android:id="@+id/rb_lent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="借出"/>
        </RadioGroup>

        <EditText
            android:id="@+id/et_asset_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_field"
            android:hint="资产名称"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <ImageView
                android:id="@+id/iv_asset_icon_preview"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_asset_icon_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="未设置图标"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_asset_icon_editor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置图标" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <EditText
                android:id="@+id/et_asset_amount"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:hint="金额"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:paddingHorizontal="16dp"
                android:textSize="16sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_currency"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:text="¥"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/input_bg"
                app:cornerRadius="16dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        </LinearLayout>

        <Spinner
            android:id="@+id/spinner_include_in_total"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_field"
            android:popupBackground="@drawable/bg_input_field"
            android:popupElevation="8dp" />

        <Spinner
            android:id="@+id/spinner_asset_color"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_field"
            android:popupBackground="@drawable/bg_input_field"
            android:popupElevation="8dp" />

        <LinearLayout
            android:id="@+id/layout_investment_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spinner_deposit_type"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_field"
                    android:popupBackground="@drawable/bg_input_field"
                    android:popupElevation="8dp" />

                <Spinner
                    android:id="@+id/spinner_interest_type"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_field"
                    android:popupBackground="@drawable/bg_input_field"
                    android:popupElevation="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <EditText
                    android:id="@+id/et_duration"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="时长(月)"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/et_interest_rate"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="年利率(%)"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"/>
            </LinearLayout>

            <EditText
                android:id="@+id/et_deposit_date"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_field"
                android:hint="存入时间: 2024-01-01"
                android:textColor="@color/text_primary"
                android:paddingHorizontal="16dp"
                android:textSize="15sp"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"/>

            <EditText
                android:id="@+id/et_expected_total"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_field"
                android:hint="预计结算资产: 0.00"
                android:textColor="@color/app_yellow"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:textSize="15sp"
                android:focusable="false"
                android:clickable="false"
                android:cursorVisible="false"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="删除"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/input_bg"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="取 消"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/input_bg"
                android:layout_marginEnd="8dp"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="确 认"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/app_yellow"
                app:cornerRadius="16dp"/>
        </LinearLayout>

        </LinearLayout>

    </ScrollView>
</androidx.cardview.widget.CardView>
