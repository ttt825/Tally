<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="24dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="添加资产"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <Spinner
            android:id="@+id/spinner_asset_type"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_field"
            android:popupBackground="@drawable/bg_input_field"
            android:popupElevation="4dp"
            android:entries="@array/asset_types" />

        <com.example.budgetapp.ui.CustomHighlightEditText
            android:id="@+id/et_asset_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:hint="资产名称"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:paddingHorizontal="16dp"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="图标"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_asset_icon_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="未设置"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/iv_asset_icon_preview"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_asset_icon_editor"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置"
                android:textColor="@color/app_blue"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_installment_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.example.budgetapp.ui.CustomHighlightEditText
                android:id="@+id/et_total_installments"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:hint="总期数"
                android:inputType="number"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:paddingHorizontal="16dp"
                android:textSize="16sp" />

            <com.example.budgetapp.ui.CustomHighlightEditText
                android:id="@+id/et_installment_amount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:hint="每期金额"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:paddingHorizontal="16dp"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_total_amount_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="总金额：¥0.00"
                android:textColor="@color/app_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingHorizontal="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <com.example.budgetapp.ui.CustomHighlightEditText
                android:id="@+id/et_asset_amount"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:hint="金额"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:paddingHorizontal="16dp"
                android:textSize="16sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_currency"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:minWidth="56dp"
                android:text="¥"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/input_bg"
                app:cornerRadius="16dp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <Spinner
            android:id="@+id/spinner_include_in_total"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:popupBackground="@drawable/bg_input_field"
            android:popupElevation="4dp" />

        <Spinner
            android:id="@+id/spinner_asset_color"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:popupBackground="@drawable/bg_input_field"
            android:popupElevation="4dp" />

        <LinearLayout
            android:id="@+id/layout_investment_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="投资明细"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spinner_deposit_type"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_field"
                    android:popupBackground="@drawable/bg_input_field"
                    android:popupElevation="4dp" />

                <Spinner
                    android:id="@+id/spinner_interest_type"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_field"
                    android:popupBackground="@drawable/bg_input_field"
                    android:popupElevation="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.example.budgetapp.ui.CustomHighlightEditText
                    android:id="@+id/et_duration"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="时长(月)"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"/>

                <com.example.budgetapp.ui.CustomHighlightEditText
                    android:id="@+id/et_interest_rate"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="年利率(%)"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"/>
            </LinearLayout>

            <com.example.budgetapp.ui.CustomHighlightEditText
                android:id="@+id/et_deposit_date"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:hint="存入时间: 选择日期"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:paddingHorizontal="16dp"
                android:textSize="15sp"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"/>

            <com.example.budgetapp.ui.CustomHighlightEditText
                android:id="@+id/et_expected_total"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_field"
                android:hint="预计结算资产: 0.00"
                android:textColor="@color/app_blue"
                android:textColorHint="@color/app_blue"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:textSize="15sp"
                android:focusable="false"
                android:clickable="false"
                android:cursorVisible="false"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="删 除"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/input_bg"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="取 消"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/input_bg"
                android:layout_marginEnd="8dp"
                app:cornerRadius="16dp"/>

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="确 认"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:backgroundTint="@color/app_blue"
                app:cornerRadius="16dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>