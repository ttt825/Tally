<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_draft_index"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="记录 1"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_transaction_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_draft_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="@color/app_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_remove"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="移除"
            android:src="@drawable/ic_delete_red"
            android:padding="8dp"
            android:scaleType="centerInside" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_draft_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_draft_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_editor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioGroup
            android:id="@+id/rg_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/rb_expense"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="支出"
                android:gravity="center"
                android:button="@null"
                android:background="@drawable/bg_type_selector"
                android:textColor="@color/text_type_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:checked="true"
                android:layout_marginEnd="4dp"/>

            <RadioButton
                android:id="@+id/rb_income"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="收入"
                android:gravity="center"
                android:button="@null"
                android:background="@drawable/bg_type_selector"
                android:textColor="@color/text_type_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="2dp"/>

            <RadioButton
                android:id="@+id/rb_liability"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="负债"
                android:gravity="center"
                android:button="@null"
                android:background="@drawable/bg_type_selector"
                android:textColor="@color/text_type_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="2dp"/>

            <RadioButton
                android:id="@+id/rb_lend"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="借出"
                android:gravity="center"
                android:button="@null"
                android:background="@drawable/bg_type_selector"
                android:textColor="@color/text_type_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"/>
        </RadioGroup>

        <com.example.budgetapp.ui.CustomHighlightEditText
            android:id="@+id/et_amount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:hint="请输入金额"
            android:inputType="numberDecimal"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorHint"
            android:paddingHorizontal="16dp"
            android:textSize="16sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:overScrollMode="never"
            android:nestedScrollingEnabled="false"
            android:background="@drawable/bg_input_field"
            android:padding="8dp"/>

        <Spinner
            android:id="@+id/sp_asset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:dropDownHeight="240dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:popupBackground="@drawable/bg_input_field"
            android:paddingHorizontal="12dp" />

        <com.example.budgetapp.ui.CustomHighlightEditText
            android:id="@+id/et_note"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:hint="添加备注"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="?android:attr/textColorHint"
            android:paddingHorizontal="16dp"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/cb_exclude_budget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="不计入预算"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="收起"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_bottom_sheet_rounded"
            android:backgroundTint="@color/app_blue"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="确认入账"
            android:textColor="@color/real_white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>